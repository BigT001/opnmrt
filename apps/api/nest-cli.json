{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "builder": {
      "webpack": {
        "config": true,
        "tsLoaderOptions": {
          "configFile": "tsconfig.json"
        }
      }
    }
  }
}